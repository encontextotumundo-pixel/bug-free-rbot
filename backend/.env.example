# Configuración de ejemplo
# Copia este archivo a .env y completa los valores

# Puerto (8080 para Railway, 3001 para local)
PORT=8080

# Ambiente (production para Railway, development para local)
NODE_ENV=production

# Rate limiting
RATE_LIMIT_WINDOW=5
RATE_LIMIT_MAX_REQUESTS=10

# Archivo de logs
LOG_FILE=events.json
